{
    "name": "lunchmoney-mcp-cloudflare",
    "version": "0.2.0",
    "private": true,
    "type": "module",
    "description": "Cloudflare Worker that exposes the LunchMoney MCP server (akutishevsky/lunchmoney-mcp) as a remote MCP endpoint with Google OAuth.",
    "scripts": {
        "setup": "bash setup.sh",
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src",
        "cf-typegen": "wrangler types",
        "test": "vitest run --passWithNoTests"
    },
    "dependencies": {
        "@akutishevsky/lunchmoney-mcp": "^2.1.0",
        "@bm1549/remote-mcp-cloudflare": "^0.2.0",
        "@modelcontextprotocol/sdk": "^1.0.0",
        "agents": "^0.12.3"
    },
    "devDependencies": {
        "@cloudflare/vitest-pool-workers": "^0.16.13",
        "@cloudflare/workers-types": "^4.20250404.0",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.4.1",
        "typescript": "^5.4.0",
        "typescript-eslint": "^8.60.1",
        "vitest": "^4.1.8",
        "wrangler": "^4.87.0"
    },
    "overrides": {
        "agents": "$agents",
        "@modelcontextprotocol/sdk": "$@modelcontextprotocol/sdk"
    }
}
